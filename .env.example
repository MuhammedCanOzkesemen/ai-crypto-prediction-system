# CoinGecko API key (Demo tier). Get one at https://www.coingecko.com/en/api/pricing
# Copy this file to .env and add your key. Do not commit .env.
COINGECKO_API_KEY=your_api_key_here

# Production default: do not zero-pad feature width to match old models (set to 1 only for emergency debug).
ALLOW_EMERGENCY_FEATURE_ALIGN=0

# Optional: Twitter/X recent search for sentiment (mock data used if unset or API errors).
# TWITTER_BEARER_TOKEN=
# TWITTER_CACHE_TTL_SEC=21600
